<!-- === START: views/index.ejs === -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lyrics Helper</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main style="max-width: 1100px; margin: 30px auto; padding: 20px; font-family: Arial, sans-serif;">
    <header style="display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px; flex-wrap: wrap;">
      <div>
        <h1 style="margin: 0 0 8px 0;">Lyrics Helper</h1>
        <p style="margin: 0 0 6px 0;">Welcome, <%= username %></p>
        <p style="margin: 0; font-size: 12px; color: #b42318;">Version: <%= pageVersion %></p>
      </div>

      <form action="/logout" method="POST">
        <button type="submit" style="padding: 10px 14px;">Logout</button>
      </form>
    </header>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
      <section style="border: 1px solid #ddd; border-radius: 10px; padding: 20px;">
        <h2 style="margin-top: 0;">Editor</h2>

        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px;">
          <input
            type="text"
            id="songTitle"
            placeholder="Song title"
            maxlength="255"
            style="flex: 1; min-width: 220px; padding: 10px;"
          />

          <label style="display: flex; align-items: center; gap: 8px;">
            <input type="checkbox" id="isPublic" />
            <span>Public</span>
          </label>
        </div>

        <textarea
          id="lyricsInput"
          placeholder="Write your lyrics here..."
          rows="16"
          style="width: 100%; padding: 12px; margin-bottom: 12px;"
        ></textarea>

        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px;">
          <button id="analyzeBtn" type="button" style="padding: 10px 14px;">Analyze</button>
          <button id="saveSongBtn" type="button" style="padding: 10px 14px; background: #0c6b58; color: #fff; border: none; border-radius: 6px;">Save Song</button>
          <button id="newSongBtn" type="button" style="padding: 10px 14px;">New Song</button>
        </div>

        <p id="saveStatus" style="min-height: 20px; margin-bottom: 16px;"></p>

        <section>
          <h2>Analysis</h2>
          <div id="analysisResults">
            <p>No analysis yet.</p>
          </div>
        </section>
      </section>

      <aside style="border: 1px solid #ddd; border-radius: 10px; padding: 20px;">
        <h2 style="margin-top: 0;">My Songs</h2>
        <div id="songsList">
          <p>Loading songs...</p>
        </div>
      </aside>
    </div>
  </main>

  <script>
    let currentSongId = null;

    const lyricsInput = document.getElementById("lyricsInput");
    const songTitle = document.getElementById("songTitle");
    const isPublic = document.getElementById("isPublic");
    const analyzeBtn = document.getElementById("analyzeBtn");
    const saveSongBtn = document.getElementById("saveSongBtn");
    const newSongBtn = document.getElementById("newSongBtn");
    const analysisResults = document.getElementById("analysisResults");
    const songsList = document.getElementById("songsList");
    const saveStatus = document.getElementById("saveStatus");

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function (match) {
        const map = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;"
        };
        return map[match];
      });
    }

    function setStatus(message, isError = false) {
      saveStatus.textContent = message;
      saveStatus.style.color = isError ? "#b42318" : "#0c6b58";
    }

    async function loadSongs() {
      songsList.innerHTML = "<p>Loading songs...</p>";

      try {
        const response = await fetch("/api/songs");
        const data = await response.json();

        if (!response.ok) {
          songsList.innerHTML = "<p>" + escapeHtml(data.details || data.error || "Failed to load songs.") + "</p>";
          return;
        }

        if (!data.songs || !data.songs.length) {
          songsList.innerHTML = "<p>No songs saved yet.</p>";
          return;
        }

        songsList.innerHTML = data.songs.map((song) => `
          <article style="border: 1px solid #ddd; border-radius: 8px; padding: 12px; margin-bottom: 12px;">
            <h3 style="margin: 0 0 8px 0;">${escapeHtml(song.title)}</h3>
            <p style="margin: 0 0 10px 0; font-size: 14px; color: #555;">
              ${song.is_public ? "Public" : "Private"}
            </p>
            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
              <button type="button" onclick="openSong(${song.id})">Load</button>
              <button type="button" onclick="deleteSong(${song.id})">Delete</button>
            </div>
          </article>
        `).join("");
      } catch (error) {
        songsList.innerHTML = "<p>Could not load songs.</p>";
      }
    }

    async function openSong(songId) {
      try {
        const response = await fetch(`/api/songs/${songId}`);
        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not load song.", true);
          return;
        }

        currentSongId = data.song.id;
        songTitle.value = data.song.title || "";
        lyricsInput.value = data.song.lyrics || "";
        isPublic.checked = !!data.song.is_public;

        setStatus(`Loaded "${data.song.title}".`);
      } catch (error) {
        setStatus("Could not load song.", true);
      }
    }

    async function saveSong() {
      const title = songTitle.value.trim();
      const lyrics = lyricsInput.value;
      const publicValue = isPublic.checked;

      if (!title) {
        setStatus("Please enter a song title.", true);
        songTitle.focus();
        return;
      }

      try {
        const url = currentSongId ? `/api/songs/${currentSongId}` : "/api/songs";
        const method = currentSongId ? "PUT" : "POST";

        const response = await fetch(url, {
          method,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title,
            lyrics,
            is_public: publicValue
          })
        });

        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not save song.", true);
          return;
        }

        if (data.songId) {
          currentSongId = data.songId;
        }

        setStatus(data.message || "Song saved.");
        await loadSongs();
      } catch (error) {
        setStatus("Could not save song.", true);
      }
    }

    async function deleteSong(songId) {
      const confirmed = window.confirm("Delete this song?");
      if (!confirmed) return;

      try {
        const response = await fetch(`/api/songs/${songId}`, {
          method: "DELETE"
        });

        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not delete song.", true);
          return;
        }

        if (currentSongId === songId) {
          currentSongId = null;
          songTitle.value = "";
          lyricsInput.value = "";
          isPublic.checked = false;
          analysisResults.innerHTML = "<p>No analysis yet.</p>";
        }

        setStatus("Song deleted.");
        await loadSongs();
      } catch (error) {
        setStatus("Could not delete song.", true);
      }
    }

    function resetEditor() {
      currentSongId = null;
      songTitle.value = "";
      lyricsInput.value = "";
      isPublic.checked = false;
      analysisResults.innerHTML = "<p>No analysis yet.</p>";
      setStatus("Ready for a new song.");
    }

    async function analyzeLyrics() {
      const lyrics = lyricsInput.value;

      try {
        const response = await fetch("/api/analyze", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ lyrics })
        });

        const data = await response.json();

        if (!response.ok) {
          analysisResults.innerHTML = "<p>Could not analyze lyrics.</p>";
          return;
        }

        analysisResults.innerHTML = `
          <div style="display: grid; grid-template-columns: repeat(2, minmax(120px, 1fr)); gap: 12px; margin-bottom: 16px;">
            <div style="border: 1px solid #ddd; padding: 12px; border-radius: 8px;"><strong>Lines</strong><br>${data.lineCount}</div>
            <div style="border: 1px solid #ddd; padding: 12px; border-radius: 8px;"><strong>Words</strong><br>${data.wordCount}</div>
            <div style="border: 1px solid #ddd; padding: 12px; border-radius: 8px;"><strong>Avg/Line</strong><br>${data.averageWordsPerLine}</div>
            <div style="border: 1px solid #ddd; padding: 12px; border-radius: 8px;"><strong>Sections</strong><br>${data.sectionCount}</div>
          </div>
          <div style="margin-bottom: 12px;">
            <h3>Detected Sections</h3>
            <p>${data.detectedSections.length ? data.detectedSections.map(escapeHtml).join(", ") : "None detected"}</p>
          </div>
          <div>
            <h3>Longest Line</h3>
            <p>${data.longestLine ? escapeHtml(data.longestLine) : "None"}</p>
          </div>
        `;
      } catch (error) {
        analysisResults.innerHTML = "<p>Could not analyze lyrics.</p>";
      }
    }

    analyzeBtn.addEventListener("click", analyzeLyrics);
    saveSongBtn.addEventListener("click", saveSong);
    newSongBtn.addEventListener("click", resetEditor);

    loadSongs();
    window.openSong = openSong;
    window.deleteSong = deleteSong;
  </script>
</body>
</html>
<!-- === END: views/index.ejs === -->
