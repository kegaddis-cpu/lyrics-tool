<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lyrics Helper</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="site-header">
    <div>
      <h1>Lyrics Helper</h1>
      <p class="welcome-text">Welcome, <%= username %></p>
      <p style="font-size: 12px; color: #b42318;">Version: <%= pageVersion %></p>
    </div>

    <form action="/logout" method="POST">
      <button type="submit" class="secondary-button">Log Out</button>
    </form>
  </header>

  <main class="app-shell">
    <section class="editor-panel">
      <div class="panel-heading">
        <h2>Write</h2>
        <p>Draft, analyze, and save your songs.</p>
      </div>

      <div class="song-meta-row">
        <input type="text" id="songTitle" placeholder="Song title" maxlength="255" />
        <label class="checkbox-row">
          <input type="checkbox" id="isPublic" />
          <span>Public</span>
        </label>
      </div>

      <textarea id="lyricsInput" placeholder="Write your lyrics here..." rows="18"></textarea>

      <div class="button-row always-visible-buttons">
        <button id="analyzeBtn" type="button">Analyze</button>
        <button id="saveSongBtn" type="button" class="save-song-button">Save Song</button>
        <button id="newSongBtn" type="button" class="secondary-button">New Song</button>
      </div>

      <p id="saveStatus" class="save-status"></p>

      <section class="results-panel">
        <h2>Analysis</h2>
        <div id="analysisResults">
          <p>No analysis yet.</p>
        </div>
      </section>
    </section>

    <aside class="songs-panel">
      <div class="panel-heading">
        <h2>My Songs</h2>
        <p>Your saved drafts and finished songs.</p>
      </div>

      <div id="songsList" class="songs-list">
        <p>Loading songs...</p>
      </div>
    </aside>
  </main>

  <script>
    let currentSongId = null;

    const lyricsInput = document.getElementById("lyricsInput");
    const songTitle = document.getElementById("songTitle");
    const isPublic = document.getElementById("isPublic");
    const analyzeBtn = document.getElementById("analyzeBtn");
    const saveSongBtn = document.getElementById("saveSongBtn");
    const newSongBtn = document.getElementById("newSongBtn");
    const analysisResults = document.getElementById("analysisResults");
    const songsList = document.getElementById("songsList");
    const saveStatus = document.getElementById("saveStatus");

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function (match) {
        const map = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;"
        };
        return map[match];
      });
    }

    function setStatus(message, isError = false) {
      saveStatus.textContent = message;
      saveStatus.classList.toggle("error-text", isError);
    }

    async function loadSongs() {
      songsList.innerHTML = "<p>Loading songs...</p>";

      try {
        const response = await fetch("/api/songs");
        const data = await response.json();

        if (!response.ok) {
          songsList.innerHTML = `
            <div class="song-error-box">
              <p><strong>Could not load songs.</strong></p>
              <p>${escapeHtml(data.details || data.error || "Unknown error")}</p>
            </div>
          `;
          return;
        }

        if (!data.songs || !data.songs.length) {
          songsList.innerHTML = "<p>No songs saved yet.</p>";
          return;
        }

        songsList.innerHTML = data.songs.map((song) => `
          <article class="song-card">
            <div class="song-card-top">
              <div>
                <h3>${escapeHtml(song.title)}</h3>
                <p>${song.is_public ? "Public" : "Private"}</p>
              </div>
            </div>
            <div class="song-card-actions">
              <button type="button" onclick="openSong(${song.id})">Load</button>
              <button type="button" class="secondary-button" onclick="deleteSong(${song.id})">Delete</button>
            </div>
          </article>
        `).join("");
      } catch (error) {
        console.error("Load songs error:", error);
        songsList.innerHTML = `
          <div class="song-error-box">
            <p><strong>Could not load songs.</strong></p>
            <p>${escapeHtml(error.message || "Unknown fetch error")}</p>
          </div>
        `;
      }
    }

    async function openSong(songId) {
      try {
        const response = await fetch(`/api/songs/${songId}`);
        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not load song.", true);
          return;
        }

        currentSongId = data.song.id;
        songTitle.value = data.song.title || "";
        lyricsInput.value = data.song.lyrics || "";
        isPublic.checked = !!data.song.is_public;

        setStatus(`Loaded "${data.song.title}".`);
      } catch (error) {
        console.error("Open song error:", error);
        setStatus("Could not load song.", true);
      }
    }

    async function saveSong() {
      const title = songTitle.value.trim();
      const lyrics = lyricsInput.value;
      const publicValue = isPublic.checked;

      if (!title) {
        setStatus("Please enter a song title.", true);
        songTitle.focus();
        return;
      }

      try {
        const url = currentSongId ? `/api/songs/${currentSongId}` : "/api/songs";
        const method = currentSongId ? "PUT" : "POST";

        const response = await fetch(url, {
          method,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title,
            lyrics,
            is_public: publicValue
          })
        });

        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not save song.", true);
          return;
        }

        if (data.songId) {
          currentSongId = data.songId;
        }

        setStatus(data.message || "Song saved.");
        await loadSongs();
      } catch (error) {
        console.error("Save song error:", error);
        setStatus("Could not save song.", true);
      }
    }

    async function deleteSong(songId) {
      const confirmed = window.confirm("Delete this song?");
      if (!confirmed) return;

      try {
        const response = await fetch(`/api/songs/${songId}`, {
          method: "DELETE"
        });

        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not delete song.", true);
          return;
        }

        if (currentSongId === songId) {
          currentSongId = null;
          songTitle.value = "";
          lyricsInput.value = "";
          isPublic.checked = false;
          analysisResults.innerHTML = "<p>No analysis yet.</p>";
        }

        setStatus("Song deleted.");
        await loadSongs();
      } catch (error) {
        console.error("Delete song error:", error);
        setStatus("Could not delete song.", true);
      }
    }

    function resetEditor() {
      currentSongId = null;
      songTitle.value = "";
      lyricsInput.value = "";
      isPublic.checked = false;
      analysisResults.innerHTML = "<p>No analysis yet.</p>";
      setStatus("Ready for a new song.");
    }

    async function analyzeLyrics() {
      const lyrics = lyricsInput.value;

      try {
        const response = await fetch("/api/analyze", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ lyrics })
        });

        const data = await response.json();

        if (!response.ok) {
          analysisResults.innerHTML = "<p>Could not analyze lyrics.</p>";
          return;
        }

        analysisResults.innerHTML = `
          <div class="stats-grid">
            <div class="stat-box"><strong>Lines</strong><span>${data.lineCount}</span></div>
            <div class="stat-box"><strong>Words</strong><span>${data.wordCount}</span></div>
            <div class="stat-box"><strong>Avg/Line</strong><span>${data.averageWordsPerLine}</span></div>
            <div class="stat-box"><strong>Sections</strong><span>${data.sectionCount}</span></div>
          </div>
          <div class="analysis-block">
            <h3>Detected Sections</h3>
            <p>${data.detectedSections.length ? data.detectedSections.map(escapeHtml).join(", ") : "None detected"}</p>
          </div>
          <div class="analysis-block">
            <h3>Longest Line</h3>
            <p>${data.longestLine ? escapeHtml(data.longestLine) : "None"}</p>
          </div>
        `;
      } catch (error) {
        console.error("Analyze error:", error);
        analysisResults.innerHTML = "<p>Could not analyze lyrics.</p>";
      }
    }

    analyzeBtn.addEventListener("click", analyzeLyrics);
    saveSongBtn.addEventListener("click", saveSong);
    newSongBtn.addEventListener("click", resetEditor);

    loadSongs();
    window.openSong = openSong;
    window.deleteSong = deleteSong;
  </script>
</body>
</html>
<!-- === END: views/index.ejs === -->
