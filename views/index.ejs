<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lyrics Helper</title>
  <link rel="stylesheet" href="/style.css?v=17" />
</head>
<body>
  <div class="desktop-scroll-shell">
    <div class="app-shell">
      <header class="topbar">
        <div class="brand-block">
          <p class="eyebrow">Lyrics workspace</p>
          <h1>Lyrics Helper</h1>
          <p class="welcome-line">Welcome, <%= username %></p>
        </div>

        <div class="topbar-actions">
          <p class="version-pill">Version <%= pageVersion %></p>
          <form action="/logout" method="POST">
            <button type="submit" class="ghost-btn">Logout</button>
          </form>
        </div>
      </header>

      <main
        class="workspace-layout is-collapsed"
        id="workspaceLayout"
        style="--panel-width: 360px; --rail-width: <%= railWidth || 72 %>px;"
      >
        <section class="panel panel-editor">
          <div class="editor-scroll">
            <div class="panel-header">
              <div class="panel-heading-block">
                <p class="panel-kicker">Editor</p>
                <h2>Write, structure, and save</h2>
              </div>
              <p class="panel-copy">
                Build songs as draggable sections, then keep the combined lyrics synced in the main editor for analysis, rhymes, and saving.
              </p>
            </div>

            <div class="meta-row">
              <div class="field-group field-grow">
                <label for="songTitle">Song title</label>
                <input type="text" id="songTitle" placeholder="Enter a title" maxlength="255" />
              </div>

              <label class="toggle-card" for="isPublic">
                <span class="toggle-copy">
                  <strong>Public</strong>
                  <small>Visible to others later</small>
                </span>
                <input type="checkbox" id="isPublic" />
              </label>
            </div>

            <section class="section-builder-card">
              <div class="section-builder-head">
                <div>
                  <p class="panel-kicker">Song sections</p>
                  <h3>Arrange your structure</h3>
                </div>
                <p class="builder-copy">
                  Add Verse, Chorus, Pre-Chorus, Bridge, Hook, Intro, and Outro blocks, then drag them into the order you want.
                </p>
              </div>

              <div class="section-type-row">
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Verse">Verse</button>
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Pre-Chorus">Pre-Chorus</button>
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Chorus">Chorus</button>
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Bridge">Bridge</button>
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Hook">Hook</button>
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Intro">Intro</button>
                <button type="button" class="secondary-btn small-btn add-section-btn" data-type="Outro">Outro</button>
              </div>

              <div id="sectionsList" class="sections-list"></div>

              <div id="sectionsEmptyState" class="sections-empty-state">
                <p class="empty-copy">No sections yet. Start by adding a Verse or Chorus above.</p>
              </div>
            </section>

            <div class="field-group editor-lyrics-group">
              <label for="lyricsInput">Full lyrics</label>
              <textarea
                id="lyricsInput"
                placeholder="Write your lyrics here, or build them from sections above..."
                rows="20"
              ></textarea>
            </div>

            <p id="saveStatus" class="status-line" aria-live="polite"></p>
          </div>
        </section>

        <div
          id="panelResizeHandle"
          class="panel-resizer"
          role="separator"
          aria-label="Resize side panel"
          aria-orientation="vertical"
        >
          <span class="panel-resizer-grip"></span>
        </div>

        <div class="side-shell">
          <div class="side-tab-rail" role="tablist" aria-label="Workspace sections">
            <button
              id="tab-library"
              class="side-tab"
              type="button"
              role="tab"
              aria-selected="false"
              aria-controls="panel-library"
              data-panel="library"
              tabindex="0"
            >
              <span class="side-tab-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 6.5A2.5 2.5 0 0 1 6.5 4H20v15.5A1.5 1.5 0 0 0 18.5 18H6.5A2.5 2.5 0 0 0 4 20.5z"></path>
                  <path d="M8 8h8"></path>
                  <path d="M8 12h8"></path>
                </svg>
              </span>
              <span class="side-tab-text">Library</span>
            </button>

            <button
              id="tab-analysis"
              class="side-tab"
              type="button"
              role="tab"
              aria-selected="false"
              aria-controls="panel-analysis"
              data-panel="analysis"
              tabindex="-1"
            >
              <span class="side-tab-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 19h16"></path>
                 
