<!-- === START: views/index.ejs === -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lyrics Helper</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="page-shell">
    <header class="topbar">
      <div class="brand-block">
        <p class="eyebrow">Lyrics workspace</p>
        <h1>Lyrics Helper</h1>
        <p class="welcome-line">Welcome, <%= username %></p>
      </div>

      <div class="topbar-actions">
        <p class="version-pill">Version: <%= pageVersion %></p>
        <form action="/logout" method="POST">
          <button type="submit" class="ghost-btn">Logout</button>
        </form>
      </div>
    </header>

    <main class="workspace-layout">
      <section class="panel panel-editor">
        <div class="panel-header">
          <div>
            <p class="panel-kicker">Editor</p>
            <h2>Write and save</h2>
          </div>
          <p class="panel-copy">Keep the writing area wide and move utilities into side drawers.</p>
        </div>

        <div class="meta-row">
          <div class="field-group field-grow">
            <label for="songTitle">Song title</label>
            <input
              type="text"
              id="songTitle"
              placeholder="Enter a title"
              maxlength="255"
            />
          </div>

          <label class="toggle-card" for="isPublic">
            <span class="toggle-copy">
              <strong>Public</strong>
              <small>Visible to others later</small>
            </span>
            <input type="checkbox" id="isPublic" />
          </label>
        </div>

        <div class="field-group">
          <label for="lyricsInput">Lyrics</label>
          <textarea
            id="lyricsInput"
            placeholder="Write your lyrics here..."
            rows="20"
          ></textarea>
        </div>

        <div class="tool-row">
          <button id="rhymingBtn" type="button" class="secondary-btn tool-btn">Rhyming</button>
          <button id="randomBtn" type="button" class="secondary-btn tool-btn">Random</button>
        </div>

        <div id="toolResults" class="tool-results" hidden>
          <div class="tool-results-head">
            <h3 id="toolResultsTitle">Writing tools</h3>
            <button id="closeToolResultsBtn" type="button" class="ghost-btn small-btn">Close</button>
          </div>
          <div id="toolResultsBody" class="tool-results-body"></div>
        </div>

        <div class="action-row">
          <button id="analyzeBtn" type="button" class="primary-btn">Analyze</button>
          <button id="saveSongBtn" type="button" class="accent-btn">Save Song</button>
          <button id="newSongBtn" type="button" class="secondary-btn">New Song</button>
        </div>

        <p id="saveStatus" class="status-line"></p>
      </section>

      <aside class="drawer-rail" aria-label="Side tools">
        <details class="drawer" id="libraryDrawer">
          <summary class="drawer-tab" title="Library">
            <span class="drawer-tab-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 6.5A2.5 2.5 0 0 1 6.5 4H20v15.5A1.5 1.5 0 0 0 18.5 18H6.5A2.5 2.5 0 0 0 4 20.5z"></path>
                <path d="M8 8h8"></path>
                <path d="M8 12h8"></path>
              </svg>
            </span>
            <span class="drawer-tab-text">Library</span>
          </summary>

          <div class="drawer-panel">
            <div class="drawer-panel-header">
              <div>
                <p class="panel-kicker">Library</p>
                <h2>My songs</h2>
              </div>
            </div>
            <p class="drawer-copy">Load, update, and remove saved songs.</p>
            <div id="songsList" class="songs-list">
              <p class="empty-copy">Loading songs...</p>
            </div>
          </div>
        </details>

        <details class="drawer" id="analysisDrawer">
          <summary class="drawer-tab" title="Analysis">
            <span class="drawer-tab-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19h16"></path>
                <path d="M7 16V9"></path>
                <path d="M12 16V5"></path>
                <path d="M17 16v-4"></path>
              </svg>
            </span>
            <span class="drawer-tab-text">Analysis</span>
          </summary>

          <div class="drawer-panel">
            <div class="drawer-panel-header">
              <div>
                <p class="panel-kicker">Analysis</p>
                <h2>Song insights</h2>
              </div>
            </div>
            <p class="drawer-copy">View structure and word-count analysis for the current draft.</p>
            <div id="analysisResults" class="analysis-results">
              <p class="empty-copy">No analysis yet.</p>
            </div>
          </div>
        </details>
      </aside>
    </main>
  </div>

  <script>
    let currentSongId = null;

    const lyricsInput = document.getElementById("lyricsInput");
    const songTitle = document.getElementById("songTitle");
    const isPublic = document.getElementById("isPublic");
    const analyzeBtn = document.getElementById("analyzeBtn");
    const saveSongBtn = document.getElementById("saveSongBtn");
    const newSongBtn = document.getElementById("newSongBtn");
    const rhymingBtn = document.getElementById("rhymingBtn");
    const randomBtn = document.getElementById("randomBtn");
    const analysisResults = document.getElementById("analysisResults");
    const songsList = document.getElementById("songsList");
    const saveStatus = document.getElementById("saveStatus");
    const libraryDrawer = document.getElementById("libraryDrawer");
    const analysisDrawer = document.getElementById("analysisDrawer");
    const toolResults = document.getElementById("toolResults");
    const toolResultsTitle = document.getElementById("toolResultsTitle");
    const toolResultsBody = document.getElementById("toolResultsBody");
    const closeToolResultsBtn = document.getElementById("closeToolResultsBtn");

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function (match) {
        const map = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;"
        };
        return map[match];
      });
    }

    function setStatus(message, isError = false) {
      saveStatus.textContent = message;
      saveStatus.classList.toggle("error", isError);
      saveStatus.classList.toggle("success", !isError && !!message);
    }

    function openOnlyDrawer(targetDrawer) {
      [libraryDrawer, analysisDrawer].forEach((drawer) => {
        if (drawer !== targetDrawer) {
          drawer.removeAttribute("open");
        }
      });
      targetDrawer.setAttribute("open", "open");
    }

    function showToolResults(title, html) {
      toolResultsTitle.textContent = title;
      toolResultsBody.innerHTML = html;
      toolResults.hidden = false;
    }

    function hideToolResults() {
      toolResults.hidden = true;
      toolResultsTitle.textContent = "Writing tools";
      toolResultsBody.innerHTML = "";
    }

    function getLastWord() {
      const text = lyricsInput.value.trim();
      if (!text) return "";
      const words = text.match(/[A-Za-z']+/g);
      return words && words.length ? words[words.length - 1].toLowerCase() : "";
    }

    function getSelectionOrLastWord() {
      const selected = lyricsInput.value
        .slice(lyricsInput.selectionStart, lyricsInput.selectionEnd)
        .trim()
        .toLowerCase();

      if (selected) return selected;
      return getLastWord();
    }

    function insertAtCursor(text) {
      const start = lyricsInput.selectionStart;
      const end = lyricsInput.selectionEnd;
      const current = lyricsInput.value;
      lyricsInput.value = current.slice(0, start) + text + current.slice(end);
      const cursor = start + text.length;
      lyricsInput.focus();
      lyricsInput.setSelectionRange(cursor, cursor);
    }

    function normalizeArray(value) {
      if (Array.isArray(value)) return value.filter(Boolean);
      if (typeof value === "string" && value.trim()) {
        return value.split(/[,\n]/).map((item) => item.trim()).filter(Boolean);
      }
      return [];
    }

    function extractRhymeSuggestions(data) {
      return [
        ...normalizeArray(data?.rhymes),
        ...normalizeArray(data?.suggestions),
        ...normalizeArray(data?.words),
        ...normalizeArray(data?.results),
        ...normalizeArray(data?.data)
      ].slice(0, 16);
    }

    function extractRandomPayload(data) {
      const prompts = [
        ...normalizeArray(data?.prompts),
        ...normalizeArray(data?.ideas),
        ...normalizeArray(data?.lines),
        ...normalizeArray(data?.suggestions)
      ];

      const words = [
        ...normalizeArray(data?.words),
        ...normalizeArray(data?.wordBank),
        ...normalizeArray(data?.keywords),
        ...normalizeArray(data?.terms)
      ];

      return {
        prompts,
        words
      };
    }

    function renderRhymeResults(sourceWord, suggestions) {
      if (!suggestions.length) {
        showToolResults(
          "Rhyming ideas",
          `<p class="empty-copy">No rhyme ideas came back for "${escapeHtml(sourceWord)}".</p>`
        );
        return;
      }

      showToolResults(
        `Rhyming ideas for "${sourceWord}"`,
        `
          <div class="tool-chip-list">
            ${suggestions.map((word) => `
              <button type="button" class="chip-btn" onclick="insertToolWord(${JSON.stringify(word)})">${escapeHtml(word)}</button>
            `).join("")}
          </div>
        `
      );
    }

    function renderRandomResults(prompts, words) {
      const prompt = prompts[0] || "Try rewriting the last line with a sharper image.";
      const wordList = words.length ? words.slice(0, 8) : ["neon", "ashes", "midnight", "mercy"];

      showToolResults(
        "Random writing prompts",
        `
          <div class="analysis-card">
            <h3>Prompt</h3>
            <p>${escapeHtml(prompt)}</p>
          </div>

          <div class="analysis-card">
            <h3>Word bank</h3>
            <div class="tool-chip-list">
              ${wordList.map((word) => `
                <button type="button" class="chip-btn" onclick="insertToolWord(${JSON.stringify(word)})">${escapeHtml(word)}</button>
              `).join("")}
            </div>
          </div>
        `
      );
    }

    function getFallbackRhymes(lastWord) {
      const rhymeMap = {
        time: ["rhyme", "climb", "chime", "prime", "shine", "sign"],
        night: ["light", "bright", "flight", "height", "sight", "write"],
        fire: ["desire", "higher", "choir", "wire", "inspire"],
        heart: ["start", "part", "art", "chart", "dark"],
        pain: ["rain", "chain", "flame", "vein", "gain"],
        love: ["above", "glove", "dove", "of"],
        dream: ["beam", "scheme", "gleam", "stream", "theme"],
        blue: ["true", "through", "you", "view", "do"],
        road: ["code", "glowed", "showed", "owed", "mode"],
        song: ["long", "strong", "wrong", "along", "belong"]
      };

      return rhymeMap[lastWord] || [
        `${lastWord} light`,
        `${lastWord} fire`,
        `${lastWord} again`,
        `${lastWord} tonight`,
        `${lastWord} inside`
      ];
    }

    function getFallbackRandom() {
      const prompts = [
        "Write one line that sounds like a confession.",
        "Flip the point of view from I to you.",
        "Add a weather image to the next bar.",
        "Rewrite the last line with fewer words.",
        "Use a concrete object instead of an emotion word.",
        "Make the next line feel like a late-night drive.",
        "Turn the next bar into a question.",
        "Add one line that raises the tension."
      ];

      const words = [
        "neon", "ashes", "velvet", "hollow", "fever", "midnight", "shadow", "mercy"
      ];

      const prompt = prompts[Math.floor(Math.random() * prompts.length)];
      const wordBank = [...words].sort(() => 0.5 - Math.random()).slice(0, 4);

      return { prompts: [prompt], words: wordBank };
    }

    libraryDrawer.addEventListener("toggle", () => {
      if (libraryDrawer.open) openOnlyDrawer(libraryDrawer);
    });

    analysisDrawer.addEventListener("toggle", () => {
      if (analysisDrawer.open) openOnlyDrawer(analysisDrawer);
    });

    closeToolResultsBtn.addEventListener("click", hideToolResults);

    async function loadSongs() {
      songsList.innerHTML = '<p class="empty-copy">Loading songs...</p>';

      try {
        const response = await fetch("/api/songs");
        const data = await response.json();

        if (!response.ok) {
          songsList.innerHTML = `<p class="empty-copy">${escapeHtml(data.details || data.error || "Failed to load songs.")}</p>`;
          return;
        }

        if (!data.songs || !data.songs.length) {
          songsList.innerHTML = '<p class="empty-copy">No songs saved yet.</p>';
          return;
        }

        songsList.innerHTML = data.songs.map((song) => `
          <article class="song-card">
            <div class="song-card-head">
              <div>
                <h3>${escapeHtml(song.title)}</h3>
                <p>${song.is_public ? "Public" : "Private"}</p>
              </div>
            </div>

            <p class="song-preview">${escapeHtml((song.lyrics || "").slice(0, 100)) || "No lyrics saved yet."}</p>

            <div class="song-card-actions">
              <button type="button" class="primary-btn small-btn" onclick="openSong(${song.id})">Load</button>
              <button type="button" class="secondary-btn small-btn" onclick="deleteSong(${song.id})">Delete</button>
            </div>
          </article>
        `).join("");
      } catch (error) {
        songsList.innerHTML = '<p class="empty-copy">Could not load songs.</p>';
      }
    }

    async function openSong(songId) {
      try {
        const response = await fetch(`/api/songs/${songId}`);
        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not load song.", true);
          return;
        }

        currentSongId = data.song.id;
        songTitle.value = data.song.title || "";
        lyricsInput.value = data.song.lyrics || "";
        isPublic.checked = !!data.song.is_public;

        setStatus(`Loaded "${data.song.title}".`);
        openOnlyDrawer(libraryDrawer);
        window.scrollTo({ top: 0, behavior: "smooth" });
      } catch (error) {
        setStatus("Could not load song.", true);
      }
    }

    async function saveSong() {
      const title = songTitle.value.trim();
      const lyrics = lyricsInput.value;
      const publicValue = isPublic.checked;

      if (!title) {
        setStatus("Please enter a song title.", true);
        songTitle.focus();
        return;
      }

      try {
        const url = currentSongId ? `/api/songs/${currentSongId}` : "/api/songs";
        const method = currentSongId ? "PUT" : "POST";

        const response = await fetch(url, {
          method,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title,
            lyrics,
            is_public: publicValue
          })
        });

        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not save song.", true);
          return;
        }

        if (data.songId) {
          currentSongId = data.songId;
        }

        setStatus(data.message || "Song saved.");
        await loadSongs();
      } catch (error) {
        setStatus("Could not save song.", true);
      }
    }

    async function deleteSong(songId) {
      const confirmed = window.confirm("Delete this song?");
      if (!confirmed) return;

      try {
        const response = await fetch(`/api/songs/${songId}`, {
          method: "DELETE"
        });

        const data = await response.json();

        if (!response.ok) {
          setStatus(data.details || data.error || "Could not delete song.", true);
          return;
        }

        if (currentSongId === songId) {
          currentSongId = null;
          songTitle.value = "";
          lyricsInput.value = "";
          isPublic.checked = false;
          analysisResults.innerHTML = '<p class="empty-copy">No analysis yet.</p>';
          hideToolResults();
        }

        setStatus("Song deleted.");
        await loadSongs();
      } catch (error) {
        setStatus("Could not delete song.", true);
      }
    }

    function resetEditor() {
      currentSongId = null;
      songTitle.value = "";
      lyricsInput.value = "";
      isPublic.checked = false;
      analysisResults.innerHTML = '<p class="empty-copy">No analysis yet.</p>';
      hideToolResults();
      setStatus("Ready for a new song.");
    }

    async function analyzeLyrics() {
      const lyrics = lyricsInput.value;

      try {
        const response = await fetch("/api/analyze", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ lyrics })
        });

        const data = await response.json();

        if (!response.ok) {
          analysisResults.innerHTML = '<p class="empty-copy">Could not analyze lyrics.</p>';
          return;
        }

        analysisResults.innerHTML = `
          <div class="stats-grid">
            <div class="stat-card">
              <span>Lines</span>
              <strong>${data.lineCount}</strong>
            </div>
            <div class="stat-card">
              <span>Words</span>
              <strong>${data.wordCount}</strong>
            </div>
            <div class="stat-card">
              <span>Avg / line</span>
              <strong>${data.averageWordsPerLine}</strong>
            </div>
            <div class="stat-card">
              <span>Sections</span>
              <strong>${data.sectionCount}</strong>
            </div>
          </div>

          <div class="analysis-card">
            <h3>Detected sections</h3>
            <p>${data.detectedSections.length ? data.detectedSections.map(escapeHtml).join(", ") : "None detected"}</p>
          </div>

          <div class="analysis-card">
            <h3>Longest line</h3>
            <p>${data.longestLine ? escapeHtml(data.longestLine) : "None"}</p>
          </div>
        `;

        openOnlyDrawer(analysisDrawer);
      } catch (error) {
        analysisResults.innerHTML = '<p class="empty-copy">Could not analyze lyrics.</p>';
      }
    }

    async function showRhymes() {
      const sourceWord = getSelectionOrLastWord();

      if (!sourceWord) {
        showToolResults(
          "Rhyming ideas",
          `<p class="empty-copy">Select a word or type a line first, then use Rhyming.</p>`
        );
        return;
      }

      showToolResults(
        "Rhyming ideas",
        `<p class="empty-copy">Loading rhyme suggestions for "${escapeHtml(sourceWord)}"...<\/p>`
      );

      try {
        const response = await fetch("/api/rhyme", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            word: sourceWord,
            lyrics: lyricsInput.value,
            title: songTitle.value.trim()
          })
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.details || data.error || "Could not fetch rhymes.");
        }

        const suggestions = extractRhymeSuggestions(data);

        if (!suggestions.length) {
          throw new Error("No rhyme suggestions returned.");
        }

        renderRhymeResults(sourceWord, suggestions);
      } catch (error) {
        renderRhymeResults(sourceWord, getFallbackRhymes(sourceWord));
        setStatus("Using fallback rhyme ideas.", true);
      }
    }

    async function showRandomIdeas() {
      showToolResults(
        "Random writing prompts",
        `<p class="empty-copy">Loading random ideas...<\/p>`
      );

      try {
        const response = await fetch("/api/random", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            lyrics: lyricsInput.value,
            title: songTitle.value.trim()
          })
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.details || data.error || "Could not fetch random ideas.");
        }

        const payload = extractRandomPayload(data);

        if (!payload.prompts.length && !payload.words.length) {
          throw new Error("No random ideas returned.");
        }

        renderRandomResults(payload.prompts, payload.words);
      } catch (error) {
        const payload = getFallbackRandom();
        renderRandomResults(payload.prompts, payload.words);
        setStatus("Using fallback random ideas.", true);
      }
    }

    analyzeBtn.addEventListener("click", analyzeLyrics);
    saveSongBtn.addEventListener("click", saveSong);
    newSongBtn.addEventListener("click", resetEditor);
    rhymingBtn.addEventListener("click", showRhymes);
    randomBtn.addEventListener("click", showRandomIdeas);

    loadSongs();
    window.openSong = openSong;
    window.deleteSong = deleteSong;
    window.insertToolWord = function (word) {
      insertAtCursor(`${word} `);
    };
  </script>
</body>
</html>
<!-- === END: views/index.ejs === -->
