<!-- === START: views/index.ejs === -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lyrics Helper</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main style="max-width: 760px; margin: 40px auto; padding: 20px; font-family: Arial, sans-serif;">
    <header style="display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px;">
      <div>
        <h1 style="margin: 0 0 8px 0;">Lyrics Helper</h1>
        <p style="margin: 0 0 6px 0;">Welcome, <%= username %></p>
        <p style="margin: 0; font-size: 12px; color: #b42318;">Version: <%= pageVersion %></p>
      </div>

      <form action="/logout" method="POST">
        <button type="submit">Logout</button>
      </form>
    </header>

    <section style="border: 1px solid #ddd; border-radius: 10px; padding: 20px;">
      <h2 style="margin-top: 0;">EJS homepage is working</h2>
      <p>If you can see this page, Express is now rendering <code>views/index.ejs</code> instead of <code>public/index.html</code>.</p>
      <p>The next step is to swap this safe test page for the full song editor with Save Song and My Songs.</p>
    </section>
  </main>
</body>
</html>
<!-- === END: views/index.ejs === -->
