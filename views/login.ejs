<!-- === START: views/login.ejs === -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Lyrics Helper</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main class="login-page">
    <section class="login-card" aria-labelledby="login-title">
      <h1 id="login-title">Lyrics Helper</h1>
      <p class="login-subtitle">Welcome back. Log in to your account.</p>

      <% if (registered) { %>
        <p class="login-success" role="status">Account created! Please log in.</p>
      <% } %>

      <form action="/login" method="POST" class="login-form">
        <label for="username">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          placeholder="Your username"
          required
          autocomplete="username"
        />

        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Your password"
          required
          autocomplete="current-password"
        />

        <button type="submit">Log In</button>
      </form>

      <% if (error) { %>
        <p class="login-error" role="alert"><%= error %></p>
      <% } %>

      <p class="login-subtitle" style="margin-top: 16px;">
        New here? <a href="/register">Create an account</a>
      </p>
    </section>
  </main>
</body>
</html>
<!-- === END: views/login.ejs === -->
